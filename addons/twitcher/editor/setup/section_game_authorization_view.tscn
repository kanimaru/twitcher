theme_override_font_sizes/normal_font_size = 12
bbcode_enabled = true
text = "A little bit more complicated then implicit, works on all machines. User needs more steps. [url=https://dev.twitch.tv/docs/authentication/getting-tokens-oauth/#device-code-grant-flow]Documention[/url]"
