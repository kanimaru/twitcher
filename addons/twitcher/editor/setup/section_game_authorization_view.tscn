[node name="ImplicitFlowExplain" type="RichTextLabel" parent="GridContainer" unique_id=1988863306]
layout_mode = 2
size_flags_horizontal = 3
theme_override_font_sizes/normal_font_size = 12
bbcode_enabled = true
text = "Easiest way for user but possibly [url=https://developer.okta.com/blog/2019/05/01/is-the-oauth-implicit-flow-dead]insecure[/url]. Also may not work on webbuilds or devices that can't host their own server. [url=https://dev.twitch.tv/docs/authentication/getting-tokens-oauth/#implicit-grant-flow]Documention[/url]"
fit_content = true
vertical_alignment = 1
script = ExtResource("2_al1px")

